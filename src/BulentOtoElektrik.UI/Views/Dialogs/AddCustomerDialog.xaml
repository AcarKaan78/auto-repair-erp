<Window x:Class="BulentOtoElektrik.UI.Views.Dialogs.AddCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Yeni Müşteri Ekle"
        Width="450" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Yeni Müşteri Ekle"
                   FontSize="20" FontWeight="Medium"
                   Margin="0,0,0,16"/>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <TextBox materialDesign:HintAssist.Hint="Ad Soyad *"
                     Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,8"/>

            <TextBox materialDesign:HintAssist.Hint="Telefon 1"
                     Text="{Binding Phone1, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,8"/>

            <TextBox materialDesign:HintAssist.Hint="Telefon 2"
                     Text="{Binding Phone2, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,8"/>

            <TextBox materialDesign:HintAssist.Hint="TC No"
                     Text="{Binding IdentityNumber, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,8"/>

            <TextBox materialDesign:HintAssist.Hint="E-posta"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,8"/>

            <TextBox materialDesign:HintAssist.Hint="Adres"
                     Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Height="60"
                     VerticalContentAlignment="Top"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="İptal"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,8,0"/>
            <Button Content="Kaydet"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource MaterialDesignRaisedSecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
