<Window x:Class="BulentOtoElektrik.UI.Views.Dialogs.AddCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Yeni Müşteri ve Araç Ekle"
        Width="380" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Style="{StaticResource MaterialDesignWindow}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Yeni Müşteri ve Araç Ekle"
                   FontSize="16" FontWeight="Medium"
                   Margin="0,0,0,10"/>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBox materialDesign:HintAssist.Hint="Ad Soyad *"
                     Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,6"/>

            <TextBox materialDesign:HintAssist.Hint="Telefon 1"
                     Text="{Binding Phone1, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,6"/>

            <TextBox materialDesign:HintAssist.Hint="Telefon 2"
                     Text="{Binding Phone2, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,6"/>

            <TextBox materialDesign:HintAssist.Hint="TC No"
                     Text="{Binding IdentityNumber, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,6"/>

            <TextBox materialDesign:HintAssist.Hint="E-posta"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,6"/>

            <TextBox materialDesign:HintAssist.Hint="Adres"
                     Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Height="50"
                     VerticalContentAlignment="Top"/>

            <!-- Vehicle Section -->
            <Separator Margin="0,8,0,6"/>
            <TextBlock Text="Araç Bilgileri" FontSize="12" FontWeight="Medium" Margin="0,0,0,6" Foreground="#757575"/>

            <TextBox materialDesign:HintAssist.Hint="Plaka *"
                     Text="{Binding PlateNumber, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,6"
                     CharacterCasing="Upper"/>

            <TextBox materialDesign:HintAssist.Hint="Marka"
                     Text="{Binding VehicleBrand, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,6"/>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Model"
                         Text="{Binding VehicleModel, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,4,0"/>
                <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Yıl"
                         Text="{Binding VehicleYear, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="4,0,0,0"/>
            </Grid>
        </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="İptal"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,8,0"/>
            <Button Content="Kaydet"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource MaterialDesignRaisedSecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
