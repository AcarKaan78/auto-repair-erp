<Window x:Class="BulentOtoElektrik.UI.Views.Dialogs.AddServiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:enums="clr-namespace:BulentOtoElektrik.Core.Enums;assembly=BulentOtoElektrik.Core"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:converters="clr-namespace:BulentOtoElektrik.UI.Converters"
        Title="Islem Ekle"
        Width="520" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}">

    <Window.Resources>
        <ObjectDataProvider x:Key="CurrencyTypeValues"
                            MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enums:CurrencyType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Islem Ekle" FontSize="20" FontWeight="Medium" Margin="0,0,0,16"/>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <TextBox materialDesign:HintAssist.Hint="Sikayet"
                     Text="{Binding Complaint, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,8" TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="60"/>

            <TextBox materialDesign:HintAssist.Hint="Yapilan Islem *"
                     Text="{Binding WorkPerformed, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,8" TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="60"/>

            <ComboBox materialDesign:HintAssist.Hint="Teknisyen"
                      ItemsSource="{Binding Technicians}"
                      SelectedItem="{Binding SelectedTechnician}"
                      DisplayMemberPath="FullName"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Miktar"
                         Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,4,0"/>

                <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Birim Fiyat"
                         Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="4,0,4,0"/>

                <ComboBox Grid.Column="2" materialDesign:HintAssist.Hint="Para Birimi"
                          ItemsSource="{Binding Source={StaticResource CurrencyTypeValues}}"
                          SelectedItem="{Binding Currency}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="4,0,0,0"/>
            </Grid>

            <DatePicker materialDesign:HintAssist.Hint="Tarih"
                        SelectedDate="{Binding ServiceDate}"
                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                        Margin="0,0,0,8"/>

            <TextBox materialDesign:HintAssist.Hint="Notlar"
                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="50"/>

            <!-- Computed Total -->
            <Border Margin="0,12,0,0" Background="#F5F5F5" CornerRadius="4" Padding="12,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Tutar: " FontSize="16" FontWeight="Medium"
                               VerticalAlignment="Center" Foreground="#757575"/>
                    <TextBlock x:Name="TotalText" FontSize="20" FontWeight="Bold"
                               VerticalAlignment="Center" Foreground="#303F9F"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Iptal" Command="{Binding CancelCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,8,0"/>
            <Button Content="Kaydet" Command="{Binding SaveCommand}"
                    Style="{StaticResource MaterialDesignRaisedSecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
