<UserControl x:Class="BulentOtoElektrik.UI.Views.Pages.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:BulentOtoElektrik.UI.Converters"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="#F5F5F5">

    <UserControl.Resources>
        <converters:CurrencyFormatConverter x:Key="CurrencyFormat"/>
        <converters:DateFormatConverter x:Key="DateFormat"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Raporlar"
                   Style="{StaticResource PageTitleStyle}"/>

        <!-- Date Range and Filters Row -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay}"
                        Width="160"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        materialDesign:HintAssist.Hint="Başlangıç"
                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>

            <DatePicker SelectedDate="{Binding EndDate, Mode=TwoWay}"
                        Width="160"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0"
                        materialDesign:HintAssist.Hint="Bitiş"
                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>

            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                    Content="Bugün"
                    Command="{Binding QuickFilterCommand}"
                    CommandParameter="Today"
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"/>

            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                    Content="Bu Hafta"
                    Command="{Binding QuickFilterCommand}"
                    CommandParameter="ThisWeek"
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"/>

            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                    Content="Bu Ay"
                    Command="{Binding QuickFilterCommand}"
                    CommandParameter="ThisMonth"
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"/>

            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                    Content="Geçen Ay"
                    Command="{Binding QuickFilterCommand}"
                    CommandParameter="LastMonth"
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"/>

            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                    Content="Bu Yıl"
                    Command="{Binding QuickFilterCommand}"
                    CommandParameter="ThisYear"
                    Margin="0,0,16,0"
                    VerticalAlignment="Center"/>

            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding LoadReportCommand}"
                    Background="#303F9F" Foreground="White"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    Padding="16,8"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ChartBar" Width="20" Height="20"
                                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Rapor Oluştur" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </WrapPanel>

        <!-- Summary Cards -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,16">
            <!-- Toplam Gelir -->
            <materialDesign:Card Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <materialDesign:PackIcon Kind="CashPlus" Width="20" Height="20"
                                                  Foreground="{StaticResource SuccessGreenBrush}"
                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Toplam Gelir"
                                   Style="{StaticResource SummaryCardLabelStyle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TotalRevenue, Converter={StaticResource CurrencyFormat}}"
                               Style="{StaticResource SummaryCardValueStyle}"
                               Foreground="{StaticResource SuccessGreenBrush}"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Toplam Gider -->
            <materialDesign:Card Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <materialDesign:PackIcon Kind="CashMinus" Width="20" Height="20"
                                                  Foreground="{StaticResource DangerRedBrush}"
                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Toplam Gider"
                                   Style="{StaticResource SummaryCardLabelStyle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TotalExpenses, Converter={StaticResource CurrencyFormat}}"
                               Style="{StaticResource SummaryCardValueStyle}"
                               Foreground="{StaticResource DangerRedBrush}"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Net Kazanç -->
            <materialDesign:Card Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <materialDesign:PackIcon Kind="Calculator" Width="20" Height="20"
                                                  Foreground="#1976D2"
                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Net Kazanç"
                                   Style="{StaticResource SummaryCardLabelStyle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding NetEarnings, Converter={StaticResource CurrencyFormat}}"
                               Style="{StaticResource SummaryCardValueStyle}"
                               Foreground="#1976D2"/>
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <!-- TabControl with 3 tabs -->
        <TabControl Grid.Row="3" Margin="0,0,0,16">

            <!-- Tab 1: Günlük Detay -->
            <TabItem Header="Günlük Detay">
                <materialDesign:Card Padding="0" UniformCornerRadius="8" Margin="0,8,0,0">
                    <DataGrid ItemsSource="{Binding DailyBreakdown}"
                              Style="{StaticResource AppDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih"
                                                Binding="{Binding Date, Converter={StaticResource DateFormat}}"
                                                Width="150"/>
                            <DataGridTextColumn Header="Gelir"
                                                Binding="{Binding Revenue, Converter={StaticResource CurrencyFormat}}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="Margin" Value="8,0"/>
                                        <Setter Property="Foreground" Value="{StaticResource SuccessGreenBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Gider"
                                                Binding="{Binding Expenses, Converter={StaticResource CurrencyFormat}}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="Margin" Value="8,0"/>
                                        <Setter Property="Foreground" Value="{StaticResource DangerRedBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Net"
                                                Binding="{Binding Net, Converter={StaticResource CurrencyFormat}}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="Margin" Value="8,0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </materialDesign:Card>
            </TabItem>

            <!-- Tab 2: Teknisyen Bazlı -->
            <TabItem Header="Teknisyen Bazlı">
                <materialDesign:Card Padding="0" UniformCornerRadius="8" Margin="0,8,0,0">
                    <DataGrid ItemsSource="{Binding TechnicianReport}"
                              Style="{StaticResource AppDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Teknisyen Adı"
                                                Binding="{Binding TechnicianName}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Margin" Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Toplam Gelir"
                                                Binding="{Binding TotalRevenue, Converter={StaticResource CurrencyFormat}}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="Margin" Value="8,0"/>
                                        <Setter Property="Foreground" Value="{StaticResource SuccessGreenBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="İşlem Sayısı"
                                                Binding="{Binding ServiceCount}"
                                                Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="Margin" Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </materialDesign:Card>
            </TabItem>

            <!-- Tab 3: Gider Dağılımı -->
            <TabItem Header="Gider Dağılımı">
                <materialDesign:Card Padding="16" UniformCornerRadius="8" Margin="0,8,0,0">
                    <lvc:PieChart Series="{Binding PieChartSeries}"
                                  MinHeight="350"
                                  Margin="0,0,0,24"/>
                </materialDesign:Card>
            </TabItem>
        </TabControl>

        <!-- Export Button -->
        <Button Grid.Row="4"
                Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                Command="{Binding ExportReportCommand}"
                HorizontalAlignment="Left"
                Padding="24,8">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="FileExcel" Width="20" Height="20"
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Excel'e Aktar" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- Loading Indicator -->
        <Grid Grid.Row="0" Grid.RowSpan="5"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
              Background="#80FFFFFF">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Width="40" Height="40"/>
                <TextBlock Text="Yükleniyor..."
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           FontSize="14"
                           Foreground="#757575"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
