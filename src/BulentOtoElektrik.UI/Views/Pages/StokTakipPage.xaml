<UserControl x:Class="BulentOtoElektrik.UI.Views.Pages.StokTakipPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:BulentOtoElektrik.UI.Converters"
             Background="#F5F5F5">

    <UserControl.Resources>
        <converters:CurrencyFormatConverter x:Key="CurrencyFormat"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <!-- Main Content -->
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Title + Summary Cards -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Stok Takip"
                           Style="{StaticResource PageTitleStyle}"/>

                <UniformGrid Columns="3" Margin="0,0,0,16">
                    <materialDesign:Card Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Toplam Malzeme"
                                       Style="{StaticResource SummaryCardLabelStyle}"/>
                            <TextBlock Text="{Binding TotalItemsCount}"
                                       Style="{StaticResource SummaryCardValueStyle}"
                                       Foreground="#303F9F"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Toplam Stok Degeri"
                                       Style="{StaticResource SummaryCardLabelStyle}"/>
                            <TextBlock Text="{Binding TotalStockValue, Converter={StaticResource CurrencyFormat}}"
                                       Style="{StaticResource SummaryCardValueStyle}"
                                       Foreground="#4CAF50"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Dusuk Stok Uyarisi"
                                       Style="{StaticResource SummaryCardLabelStyle}"/>
                            <TextBlock Text="{Binding LowStockWarningCount}"
                                       Style="{StaticResource SummaryCardValueStyle}"
                                       Foreground="#F44336"/>
                        </StackPanel>
                    </materialDesign:Card>
                </UniformGrid>
            </StackPanel>

            <!-- Row 1: Search Bar + Add Button -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Malzeme ara..."
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,16,0"
                         VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Command="{Binding ToggleAddFormCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#303F9F" Foreground="White"
                        Padding="16,8"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="20" Height="20"
                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Yeni Malzeme Ekle" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Row 2: DataGrid -->
            <materialDesign:Card Grid.Row="2" Padding="0" UniformCornerRadius="8" Margin="0,0,0,16">
                <DataGrid ItemsSource="{Binding FilteredStockItems}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          IsReadOnly="True" SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#E0E0E0"
                          RowHeight="44" FontSize="13"
                          AlternatingRowBackground="#FAFAFA"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Malzeme Adi"
                                            Binding="{Binding MaterialName}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Kalan Adet"
                                            Binding="{Binding RemainingQuantity}"
                                            Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#303F9F"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Birim Fiyat"
                                            Binding="{Binding UnitPrice, Converter={StaticResource CurrencyFormat}}"
                                            Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Toplam Deger"
                                            Binding="{Binding TotalValue, Converter={StaticResource CurrencyFormat}}"
                                            Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Setter Property="Margin" Value="8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Islemler" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                Command="{Binding DataContext.StartEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Duzenle"
                                                Width="32" Height="32">
                                            <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                Command="{Binding DataContext.DeleteStockItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Sil"
                                                Width="32" Height="32"
                                                Foreground="#F44336">
                                            <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

            <!-- Row 3: Add Form (collapsible) -->
            <materialDesign:Card Grid.Row="3" Padding="16" UniformCornerRadius="8" Margin="0,0,0,16"
                                 Visibility="{Binding IsAddFormVisible, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding NewMaterialName, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Malzeme Adi"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding NewStockQuantity, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Kalan Adet"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                    <TextBox Grid.Column="2"
                             Text="{Binding NewUnitPrice, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Birim Fiyat"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                    <Button Grid.Column="3"
                            Command="{Binding AddStockItemCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#303F9F" Foreground="White"
                            Padding="24,8"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Width="20" Height="20"
                                                      VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Ekle" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- Edit Overlay -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
              Background="#80000000">
            <materialDesign:Card Padding="24" UniformCornerRadius="12"
                                 VerticalAlignment="Center" HorizontalAlignment="Center"
                                 MinWidth="400" MaxWidth="500">
                <StackPanel>
                    <TextBlock Text="Malzeme Duzenle" FontSize="18" FontWeight="Medium" Margin="0,0,0,16"/>

                    <TextBox Text="{Binding EditMaterialName, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Malzeme Adi"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,12"/>

                    <TextBox Text="{Binding EditRemainingQuantity, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Kalan Adet"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,12"/>

                    <TextBox Text="{Binding EditUnitPrice, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Birim Fiyat"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Iptal"
                                Command="{Binding CancelEditCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Margin="0,0,8,0"/>
                        <Button Content="Kaydet"
                                Command="{Binding SaveEditCommand}"
                                Style="{StaticResource MaterialDesignRaisedSecondaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- Loading Overlay -->
        <Grid Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
              Background="#80FFFFFF">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Width="40" Height="40"/>
                <TextBlock Text="Yukleniyor..."
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           FontSize="14"
                           Foreground="#757575"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
