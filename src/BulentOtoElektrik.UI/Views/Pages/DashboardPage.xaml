<UserControl x:Class="BulentOtoElektrik.UI.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:BulentOtoElektrik.UI.Converters"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="#F5F5F5">

    <UserControl.Resources>
        <converters:CurrencyFormatConverter x:Key="CurrencyFormat"/>
        <converters:DateFormatConverter x:Key="DateFormat"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,24,24,0">
            <Grid MaxWidth="1400">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0"
                           Text="Ana Sayfa"
                           Style="{StaticResource PageTitleStyle}"/>

                <!-- Row 1: Summary Cards -->
                <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">

                    <!-- Bugun Gelir Card -->
                    <materialDesign:Card Style="{StaticResource SummaryCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="Bugun Gelir"
                                       Style="{StaticResource SummaryCardLabelStyle}"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding TodayRevenue, Converter={StaticResource CurrencyFormat}}"
                                       Style="{StaticResource SummaryCardValueStyle}"
                                       Foreground="#4CAF50"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                <materialDesign:PackIcon Width="16" Height="16" VerticalAlignment="Center">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Kind" Value="ArrowUp"/>
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RevenueChangePercent, Converter={x:Static converters:IsNegativeConverter.Instance}}" Value="True">
                                                    <Setter Property="Kind" Value="ArrowDown"/>
                                                    <Setter Property="Foreground" Value="#F44336"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                                <TextBlock VerticalAlignment="Center" FontSize="12" Margin="2,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RevenueChangePercent, Converter={x:Static converters:IsNegativeConverter.Instance}}" Value="True">
                                                    <Setter Property="Foreground" Value="#F44336"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.Text>
                                        <Binding Path="RevenueChangePercent" StringFormat="%{0:F1}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Bugun Gider Card -->
                    <materialDesign:Card Style="{StaticResource SummaryCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="Bugun Gider"
                                       Style="{StaticResource SummaryCardLabelStyle}"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding TodayExpenses, Converter={StaticResource CurrencyFormat}}"
                                       Style="{StaticResource SummaryCardValueStyle}"
                                       Foreground="#F44336"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                <materialDesign:PackIcon Width="16" Height="16" VerticalAlignment="Center">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Kind" Value="ArrowUp"/>
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ExpenseChangePercent, Converter={x:Static converters:IsNegativeConverter.Instance}}" Value="True">
                                                    <Setter Property="Kind" Value="ArrowDown"/>
                                                    <Setter Property="Foreground" Value="#F44336"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                                <TextBlock VerticalAlignment="Center" FontSize="12" Margin="2,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ExpenseChangePercent, Converter={x:Static converters:IsNegativeConverter.Instance}}" Value="True">
                                                    <Setter Property="Foreground" Value="#F44336"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.Text>
                                        <Binding Path="ExpenseChangePercent" StringFormat="%{0:F1}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Net Kazanc Card -->
                    <materialDesign:Card Style="{StaticResource SummaryCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="Net Kazanc"
                                       Style="{StaticResource SummaryCardLabelStyle}"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding NetEarnings, Converter={StaticResource CurrencyFormat}}"
                                       Style="{StaticResource SummaryCardValueStyle}"
                                       Foreground="#1976D2"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                <materialDesign:PackIcon Width="16" Height="16" VerticalAlignment="Center">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Kind" Value="ArrowUp"/>
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NetChangePercent, Converter={x:Static converters:IsNegativeConverter.Instance}}" Value="True">
                                                    <Setter Property="Kind" Value="ArrowDown"/>
                                                    <Setter Property="Foreground" Value="#F44336"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                                <TextBlock VerticalAlignment="Center" FontSize="12" Margin="2,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NetChangePercent, Converter={x:Static converters:IsNegativeConverter.Instance}}" Value="True">
                                                    <Setter Property="Foreground" Value="#F44336"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.Text>
                                        <Binding Path="NetChangePercent" StringFormat="%{0:F1}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Arac Sayisi Card -->
                    <materialDesign:Card Style="{StaticResource SummaryCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="Arac Sayisi"
                                       Style="{StaticResource SummaryCardLabelStyle}"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding VehicleCount}"
                                       Style="{StaticResource SummaryCardValueStyle}"
                                       Foreground="#607D8B"/>
                        </Grid>
                    </materialDesign:Card>

                </UniformGrid>

                <!-- Row 2: Recent Services + Top Debtors -->
                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Son Islemler -->
                    <materialDesign:Card Grid.Column="0" Padding="16" UniformCornerRadius="8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Son Islemler"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <DataGrid ItemsSource="{Binding RecentServices}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      IsReadOnly="True" SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#E0E0E0"
                                      RowHeight="40" FontSize="13"
                                      AlternatingRowBackground="#FAFAFA"
                                      HeadersVisibility="Column"
                                      MaxHeight="400"
                                      MouseDoubleClick="RecentServices_MouseDoubleClick"
                                      PreviewMouseWheel="InnerControl_PreviewMouseWheel">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tarih"
                                                        Binding="{Binding ServiceDate, Converter={StaticResource DateFormat}}"
                                                        Width="Auto" MinWidth="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="8,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Plaka"
                                                        Binding="{Binding Vehicle.PlateNumber}"
                                                        Width="Auto" MinWidth="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="#303F9F"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="8,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Yapilan Is"
                                                        Binding="{Binding WorkPerformed}"
                                                        Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="8,0"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Tutar"
                                                        Binding="{Binding TotalAmount, Converter={StaticResource CurrencyFormat}}"
                                                        Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="8,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </materialDesign:Card>

                    <!-- Right: En Borclu Musteriler -->
                    <materialDesign:Card Grid.Column="2" Padding="16" UniformCornerRadius="8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="En Borclu Musteriler"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <ListView ItemsSource="{Binding TopDebtors}"
                                      MaxHeight="400"
                                      BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="InnerControl_PreviewMouseWheel">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="AccountCircle"
                                                                         Width="24" Height="24"
                                                                         Foreground="#9E9E9E"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding FullName}"
                                                           FontSize="14"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Balance, Converter={StaticResource CurrencyFormat}}"
                                                       FontWeight="Bold"
                                                       FontSize="14"
                                                       Foreground="#F44336"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <EventSetter Event="MouseDoubleClick" Handler="TopDebtor_MouseDoubleClick"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </DockPanel>
                    </materialDesign:Card>

                </Grid>

                <!-- Row 3: Monthly Chart -->
                <materialDesign:Card Grid.Row="3" Padding="16" UniformCornerRadius="8" Margin="0,0,0,16">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Aylik Gelir/Gider Grafigi"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <lvc:CartesianChart Series="{Binding ChartSeries}"
                                            XAxes="{Binding XAxes}"
                                            YAxes="{Binding YAxes}"
                                            Height="300"
                                            Margin="0,8,0,0"/>
                    </DockPanel>
                </materialDesign:Card>

            </Grid>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
              Background="#80FFFFFF">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Width="48" Height="48"/>
                <TextBlock Text="Yukleniyor..."
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           FontSize="14" Foreground="#757575"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
