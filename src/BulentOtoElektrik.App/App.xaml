<Application x:Class="BulentOtoElektrik.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Indigo" SecondaryColor="Amber" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/BulentOtoElektrik.UI;component/Resources/Themes/ColorPalette.xaml" />
                <ResourceDictionary Source="pack://application:,,,/BulentOtoElektrik.UI;component/Resources/Styles/AppStyles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/BulentOtoElektrik.UI;component/Resources/Styles/DataGridStyles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/BulentOtoElektrik.UI;component/Resources/Styles/CardStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
